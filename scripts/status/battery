#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity) || exit
status=$(cat /sys/class/power_supply/BAT0/status)

if [ "$status" = "Discharging" ]; then
  if [ "$capacity" -gt 85 ]; then
    icon="’ēĆ"
  elif [ "$capacity" -le 85 ] && [ "$capacity" -gt 60 ]; then
    icon="’ēü"
  elif [ "$capacity" -le 60 ] && [ "$capacity" -gt 30 ]; then
    icon="’ēé"
  elif [ "$capacity" -le 30 ] && [ "$capacity" -gt 10 ]; then
    icon="’ēā"
  elif [ "$capacity" -le 10 ]; then
    icon="’ēä"
  elif [ "$capacity" -le 5 ]; then
    icon="!’ēä"
  fi

  energy_now=$(cat /sys/class/power_supply/BAT0/energy_now 2>/dev/null)
  power_now=$(cat /sys/class/power_supply/BAT0/power_now 2>/dev/null)

  if [ -n "$energy_now" ] && [ -n "$power_now" ] && [ "$power_now" -gt 0 ]; then
    time_min=$(echo "$energy_now * 60 / $power_now" | bc)
    hours=$((time_min / 60))
    minutes=$((time_min % 60))
    time=" ${hours}h${minutes}m"
  else
    time=""
  fi
else
  icon="’ć”"
  time=""
fi

printf "%s %s%%%s\n" "$icon" "$capacity" "$time"

